# Server
SERVER_PORT=8080

# Database connection (works for local MySQL and AWS RDS)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=demo_app
DB_USER=demo_user
DB_PASSWORD=demo_password

# TLS/driver behavior (set DB_USE_SSL=true for RDS in most setups)
DB_USE_SSL=false
DB_REQUIRE_SSL=false
DB_VERIFY_SERVER_CERTIFICATE=false
DB_ALLOW_PUBLIC_KEY_RETRIEVAL=true

# Connection pool tuning
DB_POOL_MIN_IDLE=2
DB_POOL_MAX_SIZE=10
DB_CONNECTION_TIMEOUT_MS=30000

# Backend startup mode:
# - maven: uses mvn spring-boot:run
# - jar: uses java -jar and supports OTEL_JAVA_AGENT_PATH
BACKEND_RUN_MODE=maven
 
# Packaged jar path used when BACKEND_RUN_MODE=jar
BACKEND_JAR_PATH=target/three-tier-backend-1.0.0.jar
 
OTEL_JAVA_AGENT_PATH=/app/Grafana_demo_app/backend/grafana-opentelemetry-java.jar
OTEL_SERVICE_NAME=astra-tasks-backend
OTEL_EXPORTER_OTLP_ENDPOINT=http://127.0.0.1:4318
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
OTEL_RESOURCE_ATTRIBUTES=service.namespace=Backend,deployment.environment=production


