# Server
SERVER_PORT=8080

# Database connection (works for local MySQL and AWS RDS)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=demo_app
DB_USER=demo_user
DB_PASSWORD=demo_password

# TLS/driver behavior (set DB_USE_SSL=true for RDS in most setups)
DB_USE_SSL=false
DB_REQUIRE_SSL=false
DB_VERIFY_SERVER_CERTIFICATE=false
DB_ALLOW_PUBLIC_KEY_RETRIEVAL=true

# Connection pool tuning
DB_POOL_MIN_IDLE=2
DB_POOL_MAX_SIZE=10
DB_CONNECTION_TIMEOUT_MS=30000
